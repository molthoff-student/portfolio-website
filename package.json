{
  "name": "hono-testing",
  "type": "module",
  "scripts": {
    "dev:frontend": "start cmd /k vite",
    "dev:worker": "start cmd /k wrangler dev --test-scheduled",
    "build": "wrangler deploy --dry-run",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "@cloudflare/workers-types": "^4.20260511.1",
    "vite": "^6.3.5",
    "vite-ssr-components": "^0.6.1",
    "wrangler": "^4.17.0"
  }
}
